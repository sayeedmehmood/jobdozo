# JobDozo server configuration
PORT=8123

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES=7d

# Database
# Default: embedded JSON store persisted to server/data/db.json (zero setup).
# To use MongoDB (e.g. the docker-compose mongo service), set:
# MONGODB_URI=mongodb://localhost:27017/JobDozo

# Optional media storage (resume / logo uploads)
# CLOUDINARY_URL=cloudinary://key:secret@cloud-name
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
